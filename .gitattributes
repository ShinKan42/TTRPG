# Auto detect text files and normalize line endings
# Git stores LF in the repo; on Windows (core.autocrlf=true) checks out CRLF
* text=auto

# Windows-specific scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Git config files — keep CRLF on Windows to avoid LF→CRLF warnings
.gitattributes text eol=crlf
.gitignore text eol=crlf
